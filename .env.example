# UCAS 运行配置示例
# 复制此文件为 .env 并根据需要修改

# 日志等级: DEBUG, INFO, WARN, ERROR
# 生产环境推荐 INFO，排查问题推荐 DEBUG
LOG_LEVEL=INFO

# SQLite 数据库文件路径
# 注意：若使用 Docker 部署，请确保此路径在 /app/data 目录下（如 /app/data/data.db）以实现持久化
DB_PATH=data.db

# 服务监听地址 (默认 0.0.0.0:8080)
# 0.0.0.0 表示监听所有网卡，方便容器内外通信及外网访问
LISTEN_ADDR=0.0.0.0:8080
